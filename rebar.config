{minimum_otp_vsn, "28"}.

{erl_first_files, [
    "src/arizona_token.erl",
    "src/arizona_scanner.erl",
    "src/arizona_markdown.erl",
    "src/arizona_markdown_processor.erl",
    "src/arizona_parser.erl"
]}.

{erl_opts, [
    debug_info,
    warnings_as_errors,
    warn_missing_spec
]}.

{deps, [
    {eqwalizer_support,
        {git_subdir, "https://github.com/whatsapp/eqwalizer.git", {branch, "main"},
            "eqwalizer_support"}},
    {markdown,
        {git_subdir, "https://github.com/arizona-framework/erlang-markdown.git", {branch, "main"},
            "apps/markdown"}}
]}.

{dialyzer, [
    {plt_apps, all_deps},
    {plt_extra_apps, [
        compiler,
        common_test,
        eunit,
        inets,
        markdown,
        syntax_tools
    ]},
    {warnings, [
        unknown,
        unmatched_returns
    ]},
    incremental
]}.

{alias, [
    {check, [
        {fmt, "--check"},
        lint,
        hank,
        xref,
        {do, "default as test dialyzer"}
    ]},
    {test, [
        {eunit, "--cover"},
        {ct, "--cover"},
        {cover, "--min_coverage 80 --verbose"},
        ex_doc
    ]},
    {ci, [
        check,
        {do, "default as test test"}
    ]}
]}.

{profiles, [
    {default, [
        {xref_checks, [
            exports_not_used
        ]}
    ]},
    {test, [
        {cover_enabled, true},
        {cover_opts, [verbose]},
        {erl_opts, [
            debug_info,
            nowarn_missing_spec,
            warnings_as_errors
        ]},
        {dialyzer, [
            {plt_apps, all_deps},
            {plt_extra_apps, [
                compiler,
                common_test,
                eunit,
                inets,
                markdown,
                syntax_tools
            ]},
            {warnings, [
                unknown,
                unmatched_returns
            ]},
            incremental
        ]},
        {extra_src_dirs, [{"test", [{recursive, true}]}]},
        {xref_checks, []}
    ]}
]}.

{project_plugins, [
    {rebar3_hex, "7.0.11"},
    {erlfmt, "1.7.0"},
    {rebar3_lint, "4.2.0"},
    {rebar3_hank, "1.4.1"},
    {rebar3_ex_doc, "0.2.31"}
]}.

{shell, [
    {apps, [arizona_core]}
]}.

{erlfmt, [
    write,
    {files, [
        "elvis.config",
        "rebar.config",
        "src/*.app.src",
        "src/**/*.erl",
        "test/**/*.erl"
    ]}
]}.

{hex, [{doc, #{provider => ex_doc}}]}.
