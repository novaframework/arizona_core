{minimum_otp_vsn, "28"}.

{erl_first_files, [
    "src/arizona_token.erl",
    "src/arizona_scanner.erl",
    "src/arizona_markdown.erl",
    "src/arizona_markdown_processor.erl",
    "src/arizona_parser.erl"
]}.

{erl_opts, [
    debug_info,
    warnings_as_errors,
    warn_missing_spec
]}.

{deps, [
    {cowboy, "2.13.0"},
    {eqwalizer_support,
        {git_subdir, "https://github.com/whatsapp/eqwalizer.git", {branch, "main"},
            "eqwalizer_support"}},
    {markdown,
        {git_subdir, "https://github.com/arizona-framework/erlang-markdown.git", {branch, "main"},
            "apps/markdown"}}
]}.

{dialyzer, [
    {plt_apps, all_deps},
    {plt_extra_apps, [
        compiler,
        common_test,
        cowboy,
        eunit,
        inets,
        markdown,
        syntax_tools
    ]},
    {warnings, [
        unknown,
        unmatched_returns
    ]},
    incremental
]}.

{alias, [
    {check, [
        {fmt, "--check"},
        lint,
        hank,
        xref,
        {do, "default as test dialyzer"}
    ]},
    {test, [
        {eunit, "--cover"},
        {ct, "--cover"},
        {cover, "--min_coverage 80 --verbose"},
        ex_doc
    ]},
    {ci, [
        check,
        {do, "default as test test"}
    ]}
]}.

{profiles, [
    {default, [
        {xref_checks, [
            exports_not_used
        ]}
    ]},
    {test, [
        {cover_enabled, true},
        {cover_opts, [verbose]},
        {erl_opts, [
            debug_info,
            nowarn_missing_spec,
            warnings_as_errors
        ]},
        {dialyzer, [
            {plt_apps, all_deps},
            {plt_extra_apps, [
                compiler,
                common_test,
                eunit,
                inets,
                markdown,
                syntax_tools
            ]},
            {warnings, [
                unknown,
                unmatched_returns
            ]},
            incremental
        ]},
        {extra_src_dirs, [{"test", [{recursive, true}]}]},
        {xref_checks, []}
    ]}
]}.

{project_plugins, [
    covertool,
    rebar3_sbom,
    rebar3_audit,
    {rebar3_hex, "7.0.11"},
    {erlfmt, "1.7.0"},
    {rebar3_lint, "4.2.0"},
    {rebar3_hank, "1.4.1"},
    {rebar3_ex_doc, "0.2.31"}
]}.

{ex_doc, [
    {source_url, <<"https://github.com/novaframework/arizona_core">>},
    {homepage_url, <<"https://github.com/novaframework/arizona_core">>},
    {extras, [<<"README.md">>, <<"LICENSE.md">>]},
    {main, <<"readme">>},
    {proglang, erlang},
    {api_reference, true},
    {groups_for_modules, [
        {<<"Core">>, [
            arizona_template,
            arizona_scanner,
            arizona_parser
        ]},
        {<<"Components">>, [
            arizona_stateful,
            arizona_stateless,
            arizona_view
        ]},
        {<<"Rendering">>, [
            arizona_renderer,
            arizona_differ,
            arizona_hierarchical,
            arizona_tracker
        ]},
        {<<"Live">>, [
            arizona_live,
            arizona_action,
            arizona_pubsub
        ]},
        {<<"Formats">>, [
            arizona_html,
            arizona_erl,
            arizona_markdown,
            arizona_markdown_processor
        ]},
        {<<"Request">>, [
            arizona_request,
            arizona_cowboy_request
        ]},
        {<<"Internal">>, [
            arizona_parse_transform,
            arizona_lifecycle,
            arizona_token,
            arizona_tracker_dict,
            arizona_hierarchical_dict
        ]}
    ]}
]}.

{shell, [
    {apps, [arizona_core]}
]}.

{erlfmt, [
    write,
    {files, [
        "elvis.config",
        "rebar.config",
        "src/*.app.src",
        "src/**/*.erl",
        "test/**/*.erl"
    ]}
]}.

{hex, [{doc, #{provider => ex_doc}}]}.
